{
  "name": "property-fee-collection-service",
  "version": "1.1.0",
  "description": "物业费催缴后端服务 - 供收费系统、短信平台和客服工具调用",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "ts-node src/server.ts",
    "seed": "ts-node src/seed.ts",
    "mini-seed": "ts-node src/mini-seed.ts",
    "seed:small": "ts-node src/mini-seed.ts",
    "seed:full": "ts-node src/seed.ts",
    "reset": "del property-fee.db 2>nul & ts-node src/mini-seed.ts",
    "clean": "del property-fee.db 2>nul",
    "test": "node test-api.mjs"
  },
  "dependencies": {
    "express": "^4.18.2",
    "sql.js": "^1.10.3",
    "dayjs": "^1.11.10",
    "uuid": "^9.0.1",
    "csv-writer": "^1.6.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/uuid": "^9.0.7",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2"
  }
}
